import { includeIgnoreFile } from "@eslint/compat";
import javascript from "@eslint/js";
import prettier from "eslint-config-prettier";
import jsdoc from "eslint-plugin-jsdoc";
{{#if vitest}}
import vitest from "@vitest/eslint-plugin";
{{/if}}
{{#if react}}
import react from "eslint-plugin-react";
import reactHooks from 'eslint-plugin-react-hooks';
{{/if}}
import { defineConfig } from "eslint/config";
import globals from "globals";
import { fileURLToPath } from "node:url";
{{#if typescript}}
import typescript from "typescript-eslint";
{{/if}}

const GITIGNORE_PATH = fileURLToPath(new URL(".gitignore", import.meta.url));

export default defineConfig([
  includeIgnoreFile(GITIGNORE_PATH),
  {
    ignores: ["**/*.d.ts"],
  },
  javascript.configs.recommended,
  {{#if vitest}}
  {
    files: ["**/*.test.{{extensions}}"],
    ...vitest.configs.recommended,
  },
  {{/if}}
  {{#if react}}
  react.configs.flat.recommended,
  reactHooks.configs['recommended-latest'],
  {{/if}}
  {{#if typescript}}
  ...typescript.configs.recommendedTypeChecked,
  {
    languageOptions: {
      parserOptions: {
        projectService: true,
        tsconfigRootDir: import.meta.dirname,
      },
    },
  },
  {{/if}}
  {{#if typescript}}
  jsdoc.configs["flat/recommended-typescript"],
  {{else}}
  jsdoc.configs["flat/recommended"],
  {{/if}}
  {
    rules: {
      "jsdoc/tag-lines": ["warn", "any", { startLines: 1 }],
      {{#if react}}
      "jsdoc/require-param": ["warn", { interfaceExemptsParamsCheck: true }],
      "jsdoc/require-returns": ["warn", { contexts: [":function:not([id.name=/^[A-Z]/])"] }],
      {{/if}}
      "jsdoc/require-throws-type": "off",
      "jsdoc/require-hyphen-before-param-description": ["warn", "never"],
    },
  },
  prettier,
  {
    files: ["**/*.{{extensions}}"],
    languageOptions: {
      globals: {
        {{#if browser}}
        ...globals.browser,
        {{/if}}
        {{#if node}}
        ...globals.node,
        {{/if}}
      },
    },
  },
]);
